rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function esPastorOAdmin() {
      return isSignedIn() && request.auth.token.rol in ['pastor', 'administrador'];
    }

    function esAdminDeMinisterio(ministerioId) {
      return esPastorOAdmin()
        || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.administer.ministerios.hasAny([ministerioId]);
    }

    function esAdminDeCelula(celulaId) {
      return esPastorOAdmin()
        || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.administer.celulas.hasAny([celulaId]);
    }

    function esAdminDeEscuela(escuelaId) {
      return esPastorOAdmin()
        || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.administer.escuelas.hasAny([escuelaId]);
    }

    function esProfesorEM(escuelaId) {
      let escuela = get(/databases/$(database)/documents/escuela_ministerios/$(escuelaId));
      return isSignedIn() && escuela.data.profesores.any(p, p.usuarioId == request.auth.uid);
    }

    // ---------------------------------------------------------------------
    // usuarios
    // ---------------------------------------------------------------------
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn()
        && (resource.data.authUid == request.auth.uid
            || request.auth.uid == userId
            || esPastorOAdmin());
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // ministerios
    // ---------------------------------------------------------------------
    match /ministerios/{ministerioId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // ramas_celular
    // ---------------------------------------------------------------------
    match /ramas_celular/{ramaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // celulas
    // ---------------------------------------------------------------------
    match /celulas/{celulaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        esPastorOAdmin()
        || esAdminDeCelula(celulaId)
      );
      allow update: if isSignedIn() && (
        esPastorOAdmin()
        || resource.data.liderId == request.auth.uid
        || resource.data.coliderId == request.auth.uid
        || (resource.data.ramaId != null
            && get(/databases/$(database)/documents/ramas_celular/$(resource.data.ramaId)).data.encargadoId == request.auth.uid)
      );
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // eventos
    // ---------------------------------------------------------------------
    match /eventos/{eventoId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // cronogramas
    // ---------------------------------------------------------------------
    match /cronogramas/{cronogramaId} {
      allow read: if isSignedIn();
      allow create: if esPastorOAdmin();
      allow update: if isSignedIn() && (
        esPastorOAdmin()
        || resource.data.asignados.hasAny([request.auth.uid])
      );
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // tareas
    // ---------------------------------------------------------------------
    match /tareas/{tareaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // notificaciones
    // ---------------------------------------------------------------------
    match /notificaciones/{notifId} {
      allow read: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.usuarioId != request.auth.uid;
      allow update: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // asistencias
    // ---------------------------------------------------------------------
    match /asistencias/{asistenciaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // miembros_ministerio
    // ---------------------------------------------------------------------
    match /miembros_ministerio/{miembroId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin() || esAdminDeMinisterio(resource.data.ministerioId);
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // consultas
    // ---------------------------------------------------------------------
    match /consultas/{consultaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.de == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.de == request.auth.uid
            || resource.data.a == request.auth.uid
            || esPastorOAdmin());
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // miembros_celula
    // ---------------------------------------------------------------------
    match /miembros_celula/{miembroId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (
        esPastorOAdmin()
        || esAdminDeCelula(resource.data.celulaId)
      );
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // personas
    // ---------------------------------------------------------------------
    match /personas/{personaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        esPastorOAdmin()
        || resource.data.usuarioId == request.auth.uid
      );
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // historial_persona
    // ---------------------------------------------------------------------
    match /personas/{personaId}/historial/{eventoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // reporte_celulas
    // ---------------------------------------------------------------------
    match /reporte_celulas/{reporteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        esPastorOAdmin()
        || esAdminDeCelula(resource.data.celulaId)
        || request.auth.uid == request.resource.data.createdBy
      );
      allow update: if isSignedIn() && (
        esPastorOAdmin()
        || request.auth.uid == resource.data.createdBy
      );
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // miembros_iglesia (legacy, read-only)
    // ---------------------------------------------------------------------
    match /miembros_iglesia/{miembroId} {
      allow read: if esPastorOAdmin();
      allow create, update: if false;
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // escuela_ministerios
    // ---------------------------------------------------------------------
    match /escuela_ministerios/{nivelId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // asistencias_escuela_ministerios
    // ---------------------------------------------------------------------
    match /asistencias_escuela_ministerios/{docId} {
      allow read: if esPastorOAdmin()
        || esProfesorEM(resource.data.escuelaId)
        || request.auth.uid == resource.data.usuarioId;
      allow create, update: if esPastorOAdmin()
        || esProfesorEM(request.resource.data.escuelaId);
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // notas_escuela_ministerios
    // ---------------------------------------------------------------------
    match /notas_escuela_ministerios/{docId} {
      allow read: if esPastorOAdmin()
        || esProfesorEM(resource.data.escuelaId)
        || request.auth.uid == resource.data.usuarioId;
      allow create, update: if esPastorOAdmin()
        || esProfesorEM(request.resource.data.escuelaId);
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Deny everything else by default
    // ---------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
