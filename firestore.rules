rules_version = '2';

// =============================================================================
// Firestore Security Rules · SIDS
// =============================================================================
// Reemplaza la regla de "30 días" que vence el 1 de julio 2026.
// Bloquea acceso público y exige autenticación. Las operaciones destructivas
// (delete) NO se hacen desde el cliente: se delega a Cloud Functions
// (functions/src/index.ts -> borrarDocumento), que valida el custom claim
// `rol` (pastor | administrador | lider | colaborador) y aplica una
// allowlist de colecciones. Ver TODO al final.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function esPastorOAdmin() {
      return isSignedIn() && request.auth.token.rol in ['pastor', 'administrador'];
    }

    function esLider() {
      return isSignedIn() && request.auth.token.rol == 'lider';
    }

    function puedeCrearEventosOCronogramas() {
      return esPastorOAdmin() || esLider();
    }

    function puedeActualizarCronograma() {
      return puedeCrearEventosOCronogramas() || isSignedIn();
    }

    // ---------------------------------------------------------------------
    // usuarios: cualquier autenticado lee; solo autenticado puede actualizar
    //           su propio documento (matching por authUid)
    // ---------------------------------------------------------------------
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn()
        && (resource.data.authUid == request.auth.uid
            || request.auth.uid == userId
            || esPastorOAdmin());
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // ministerios: lectura para autenticados
    // ---------------------------------------------------------------------
    match /ministerios/{ministerioId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // celulas (sub-colección de ministerios): lideres/celulas pueden
    // gestionar su célula, pastor/admin pueden ver/crear/editar todas
    // ---------------------------------------------------------------------
    match /celulas/{celulaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // eventos
    // ---------------------------------------------------------------------
    match /eventos/{eventoId} {
      allow read: if isSignedIn();
      allow create, update: if puedeCrearEventosOCronogramas();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // cronogramas (grillas de servicio)
    // ---------------------------------------------------------------------
    match /cronogramas/{cronogramaId} {
      allow read: if isSignedIn();
      allow create: if puedeCrearEventosOCronogramas();
      allow update: if puedeActualizarCronograma();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // tareas
    // ---------------------------------------------------------------------
    match /tareas/{tareaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // notificaciones: SOLO el destinatario (por usuarioId) puede leer/actualizar/borrar
    // ---------------------------------------------------------------------
    match /notificaciones/{notifId} {
      allow read: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.usuarioId != request.auth.uid;
      allow update: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // asistencias (plural, igual que el código)
    // ---------------------------------------------------------------------
    match /asistencias/{asistenciaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // miembros_ministerio (si existe)
    // ---------------------------------------------------------------------
    match /miembros_ministerio/{miembroId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // consultas (sistema de mensajes líder → pastor/admin)
    // ---------------------------------------------------------------------
    match /consultas/{consultaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.de == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.de == request.auth.uid
            || resource.data.a == request.auth.uid
            || esPastorOAdmin());
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Deny everything else by default (fail-safe)
    // ---------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


