rules_version = '2';

// =============================================================================
// Firestore Security Rules · SIDS
// =============================================================================
// Reemplaza la regla de "30 días" que vence el 1 de julio 2026.
// Bloquea acceso público y exige autenticación. Las operaciones destructivas
// (delete) NO se hacen desde el cliente: se delega a Cloud Functions
// (functions/src/index.ts -> borrarDocumento), que valida el custom claim
// `rol` (pastor | administrador | lider | colaborador) y aplica una
// allowlist de colecciones. Ver TODO al final.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function esPastorOAdmin() {
      return isSignedIn() && request.auth.token.rol in ['pastor', 'administrador'];
    }

    function esLider() {
      return isSignedIn() && request.auth.token.rol == 'lider';
    }

    function esLiderOArea() {
      return isSignedIn() && request.auth.token.rol in ['lider', 'lider_area'];
    }

    function puedeCrearEventosOCronogramas() {
      return esPastorOAdmin() || esLider();
    }

    function puedeActualizarCronograma() {
      return puedeCrearEventosOCronogramas() || isSignedIn();
    }

    // ---------------------------------------------------------------------
    // usuarios: cualquier autenticado lee; solo autenticado puede actualizar
    //           su propio documento (matching por authUid)
    // ---------------------------------------------------------------------
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn()
        && (resource.data.authUid == request.auth.uid
            || request.auth.uid == userId
            || esPastorOAdmin());
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // ministerios: lectura para autenticados
    // ---------------------------------------------------------------------
    match /ministerios/{ministerioId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // ramas_celular
    // ---------------------------------------------------------------------
    match /ramas_celular/{ramaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // celulas: pastor/admin todo; encargado de rama su rama; líder/colíder/anfitrión su célula
    // ---------------------------------------------------------------------
    match /celulas/{celulaId} {
      allow read: if isSignedIn() && (
        esPastorOAdmin()
        || resource.data.liderId == request.auth.uid
        || resource.data.coliderId == request.auth.uid
        || resource.data.anfitrionId == request.auth.uid
        || (resource.data.ramaId != null
            && get(/databases/$(database)/documents/ramas_celular/$(resource.data.ramaId)).data.encargadoId == request.auth.uid)
      );
      allow create: if isSignedIn() && (
        esPastorOAdmin()
        || (request.resource.data.ramaId != null
            && get(/databases/$(database)/documents/ramas_celular/$(request.resource.data.ramaId)).data.encargadoId == request.auth.uid)
      );
      allow update: if isSignedIn() && (
        esPastorOAdmin()
        || resource.data.liderId == request.auth.uid
        || resource.data.coliderId == request.auth.uid
        || (resource.data.ramaId != null
            && get(/databases/$(database)/documents/ramas_celular/$(resource.data.ramaId)).data.encargadoId == request.auth.uid)
      );
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // eventos
    // ---------------------------------------------------------------------
    match /eventos/{eventoId} {
      allow read: if isSignedIn();
      allow create, update: if puedeCrearEventosOCronogramas();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // cronogramas (grillas de servicio)
    // ---------------------------------------------------------------------
    match /cronogramas/{cronogramaId} {
      allow read: if isSignedIn();
      allow create: if puedeCrearEventosOCronogramas();
      allow update: if puedeActualizarCronograma();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // tareas
    // ---------------------------------------------------------------------
    match /tareas/{tareaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // notificaciones: SOLO el destinatario (por usuarioId) puede leer/actualizar/borrar
    // ---------------------------------------------------------------------
    match /notificaciones/{notifId} {
      allow read: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.usuarioId != request.auth.uid;
      allow update: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.usuarioId == request.auth.uid;
    }

    // ---------------------------------------------------------------------
    // asistencias (plural, igual que el código)
    // ---------------------------------------------------------------------
    match /asistencias/{asistenciaId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // miembros_ministerio (si existe)
    // ---------------------------------------------------------------------
    match /miembros_ministerio/{miembroId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // consultas (sistema de mensajes líder → pastor/admin)
    // ---------------------------------------------------------------------
    match /consultas/{consultaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.de == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.de == request.auth.uid
            || resource.data.a == request.auth.uid
            || esPastorOAdmin());
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // miembros_celula: miembros de una célula
    // ---------------------------------------------------------------------
    match /miembros_celula/{miembroId} {
      allow read: if isSignedIn() && (
        esPastorOAdmin()
        || (resource.data.celulaId != null
            && get(/databases/$(database)/documents/celulas/$(resource.data.celulaId)).data.liderId == request.auth.uid)
        || (resource.data.celulaId != null
            && get(/databases/$(database)/documents/celulas/$(resource.data.celulaId)).data.coliderId == request.auth.uid)
        || (resource.data.celulaId != null
            && get(/databases/$(database)/documents/celulas/$(resource.data.celulaId)).data.anfitrionId == request.auth.uid)
      );
      allow create, update: if isSignedIn()
        && (esPastorOAdmin()
            || request.auth.uid == request.resource.data.createdBy
            || request.auth.uid == resource.data.createdBy);
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // personas: base central de miembros de la iglesia
    // ---------------------------------------------------------------------
    match /personas/{personaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (esPastorOAdmin() || esLiderOArea());
      allow update: if isSignedIn() && (esPastorOAdmin() || esLiderOArea());
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // historial_persona: línea de tiempo de cada persona
    // ---------------------------------------------------------------------
    match /personas/{personaId}/historial/{eventoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (esPastorOAdmin() || esLiderOArea());
      allow update: if esPastorOAdmin();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // reporte_celulas: reportes semanales de células
    // ---------------------------------------------------------------------
    match /reporte_celulas/{reporteId} {
      allow read: if isSignedIn() && (
        esPastorOAdmin()
        || resource.data.liderId == request.auth.uid
        || resource.data.createdBy == request.auth.uid
        || (resource.data.celulaId != null
            && get(/databases/$(database)/documents/celulas/$(resource.data.celulaId)).data.liderId == request.auth.uid)
        || (resource.data.celulaId != null
            && get(/databases/$(database)/documents/celulas/$(resource.data.celulaId)).data.coliderId == request.auth.uid)
      );
      allow create: if isSignedIn()
        && (esPastorOAdmin() || request.auth.uid == request.resource.data.createdBy);
      allow update: if isSignedIn()
        && (esPastorOAdmin() || request.auth.uid == resource.data.createdBy);
      allow delete: if false;
    }

    // =============================================================
    // Nuevos helpers para expansión ministerial
    // =============================================================
    
    function esLiderArea() {
      return isSignedIn() && request.auth.token.rol == 'lider_area';
    }
    
    function esMaestraEB() {
      return isSignedIn() && request.auth.token.rol == 'maestra_escuela_biblica';
    }
    
    function esProfesorEM(escuelaId) {
      let escuela = get(/databases/$(database)/documents/escuela_ministerios/$(escuelaId));
      return isSignedIn() && escuela.data.profesores.any(p, p.usuarioId == request.auth.uid);
    }
    
    function esLiderRama(ramaId) {
      let rama = get(/databases/$(database)/documents/ramas_celular/$(ramaId));
      return isSignedIn() && rama.data.encargadoId == request.auth.uid;
    }
    
    // =============================================================
    // miembros_iglesia: solo pastor/admin
    // =============================================================
    match /miembros_iglesia/{miembroId} {
      allow read: if esPastorOAdmin();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }
    
    // =============================================================
    // escuela_ministerios: lectura pública, creación pastor/admin
    // =============================================================
    match /escuela_ministerios/{nivelId} {
      allow read: if isSignedIn();
      allow create, update: if esPastorOAdmin();
      allow delete: if false;
    }
    
    // =============================================================
    // asistencias_escuela_ministerios: profesor/admin o alumno
    // =============================================================
    match /asistencias_escuela_ministerios/{docId} {
      allow read: if esPastorOAdmin() 
        || esProfesorEM(resource.data.escuelaId)
        || request.auth.uid == resource.data.usuarioId;
      allow create, update: if esPastorOAdmin() 
        || esProfesorEM(request.resource.data.escuelaId);
      allow delete: if false;
    }
    
    // =============================================================
    // notas_escuela_ministerios: profesor/admin o alumno
    // =============================================================
    match /notas_escuela_ministerios/{docId} {
      allow read: if esPastorOAdmin() 
        || esProfesorEM(resource.data.escuelaId) 
        || request.auth.uid == resource.data.usuarioId;
      allow create, update: if esPastorOAdmin() 
        || esProfesorEM(request.resource.data.escuelaId);
      allow delete: if false;
    }
    
    // ---------------------------------------------------------------------
    // Deny everything else by default (fail-safe)
    // ---------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


